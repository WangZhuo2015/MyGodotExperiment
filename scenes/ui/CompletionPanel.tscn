[gd_scene load_steps=2 format=3 uid="uid://completion_panel"]

[ext_resource type="Script" path="res://scripts/ui/CompletionPanel.gd" id="1"]

[node name="CompletionPanel" type="PanelContainer"]
script = ExtResource("1")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 8

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2

[node name="StatusLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "Room complete"

[node name="ButtonRow" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2

[node name="SaveButton" type="Button" parent="MarginContainer/VBoxContainer/ButtonRow"]
layout_mode = 2
text = "Save"

[node name="ResetButton" type="Button" parent="MarginContainer/VBoxContainer/ButtonRow"]
layout_mode = 2
text = "Reset demo"
